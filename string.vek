builtin string {
  fn to_cstr(self) -> cstr;
  unsafe fn from_cstr(source: cstr) -> string;

  inline fn is_empty(self) -> bool {
    return self.length() == 0;
  }

  fn starts_with(self, prefix: string) -> bool {
    if prefix.length() > self.length() {
      return false;
    }
    let i: usize = 0;
    while i < prefix.length() {
      if !self[i].equals(prefix[i]) {
        return false;
      }
      i = i + 1;
    }
    return true;
  }

  fn ends_with(self, suffix: string) -> bool {
    if suffix.length() > self.length() {
      return false;
    }
    let offset: usize = self.length() - suffix.length();
    let i: usize = 0;
    while i < suffix.length() {
      if !self[offset + i].equals(suffix[i]) {
        return false;
      }
      i = i + 1;
    }
    return true;
  }

  fn contains(self, needle: string) -> bool {
    if needle.length() > self.length() {
      return false;
    }
    if needle.length() == 0 {
      return true;
    }
    let limit: usize = self.length() - needle.length() + 1;
    let i: usize = 0;
    while i < limit {
      let j: usize = 0;
      let matched: bool = true;
      while j < needle.length() {
        if !self[i + j].equals(needle[j]) {
          matched = false;
          break;
        }
        j = j + 1;
      }
      if matched {
        return true;
      }
      i = i + 1;
    }
    return false;
  }

  satisfies Length {
    fn length(self) -> usize;
  }

  satisfies Equal<string> {
    fn equals(self, other: string) -> bool;
  }

  satisfies Add<string, string> {
    fn add(self, rhs: string) -> string;
  }

  satisfies Index<usize, string> {
    fn index_get(self, index: usize) -> string;
  }

  satisfies Clone {
    fn clone(self) -> string;
  }

  satisfies Default {
    inline fn default() -> Self {
      return "";
    }
  }

  satisfies Format {
    inline fn format(self) -> string {
      return self.clone();
    }
  }
}
